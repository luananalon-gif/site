<!doctype html>
<html lang="pt-BR">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>Diário de Viagens</title>
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="styles.css">
</head>
<body>
  <!-- Decorações em SVG -->
  <div class="decoration decoration-top-left" aria-hidden="true">
    <!-- flor -->
    <svg viewBox="0 0 120 120" width="140" height="140" fill="none" xmlns="http://www.w3.org/2000/svg">
      <g transform="translate(10,10)" opacity="0.12">
        <circle cx="50" cy="50" r="12" fill="#FF9CCF"/>
        <g fill="#FFD6EA">
          <ellipse cx="50" cy="15" rx="12" ry="22"/>
          <ellipse cx="85" cy="50" rx="22" ry="12" transform="rotate(90 85 50)"/>
          <ellipse cx="50" cy="85" rx="12" ry="22"/>
          <ellipse cx="15" cy="50" rx="22" ry="12" transform="rotate(90 15 50)"/>
        </g>
      </g>
    </svg>
  </div>

  <div class="decoration decoration-bottom-right" aria-hidden="true">
    <!-- concha -->
    <svg viewBox="0 0 120 120" width="160" height="120" xmlns="http://www.w3.org/2000/svg">
      <g transform="translate(0,5)" opacity="0.10">
        <path d="M10 90 C30 30, 90 30, 110 90 C90 80, 60 75, 10 90 Z" fill="#FFDFAF"/>
        <path d="M20 85 C40 50, 80 50, 100 85" stroke="#FFC77A" stroke-width="4" fill="none"/>
        <circle cx="60" cy="55" r="6" fill="#FFDFAF"/>
      </g>
    </svg>
  </div>

  <main class="container">
    <header class="site-header">
      <h1>Diário de Viagens</h1>
      <p class="subtitle">Registre suas fotos, frases e memórias</p>
    </header>

    <section class="new-trip">
      <form id="tripForm">
        <div class="row">
          <label for="title">Título (opcional)</label>
          <input id="title" name="title" type="text" placeholder="Ex.: Praia do Sol"/>
        </div>

        <div class="row">
          <label for="phrase">Frase / Legenda</label>
          <input id="phrase" name="phrase" type="text" placeholder="Uma frase curta que represente a viagem" required/>
        </div>

        <div class="row">
          <label for="comment">Comentário</label>
          <textarea id="comment" name="comment" rows="3" placeholder="Conte um pouco sobre o momento"></textarea>
        </div>

        <div class="row">
          <label for="photo">Foto</label>
          <input id="photo" name="photo" type="file" accept="image/*"/>
        </div>

        <div class="actions">
          <button type="submit" class="btn primary">Salvar viagem</button>
          <button type="button" id="clearAll" class="btn ghost">Apagar tudo</button>
        </div>
      </form>
    </section>

    <section class="trips">
      <h2>Minhas viagens</h2>
      <div id="tripsList" class="trips-grid" aria-live="polite"></div>
    </section>
  </main>

  <!-- Modal de visualização -->
  <div id="modal" class="modal" aria-hidden="true">
    <div class="modal-content">
      <button id="modalClose" class="modal-close" aria-label="Fechar">✕</button>
      <img id="modalImage" src="" alt="Foto da viagem"/>
      <div id="modalText" class="modal-text"></div>
    </div>
  </div>

  <script src="app.js" defer></script>
</body>
</html>